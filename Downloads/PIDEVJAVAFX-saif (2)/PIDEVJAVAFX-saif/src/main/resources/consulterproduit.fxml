<?xml version="1.0" encoding="UTF-8"?>

<!-- Suppression de l'import GluonHQ -->

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #faf5f0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.ConsulterProduitController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <VBox prefWidth="280" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #78350f, #451a03); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 5, 0);">
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 30 20 25 20;">
                <Label style="-fx-font-size: 45px;" text="📦" />
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="SMART FARM" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Gestion Agricole" />
            </VBox>
            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />
            <VBox spacing="5" style="-fx-padding: 20 15;">
                <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="NAVIGATION" />
                <Button alignment="CENTER_LEFT" prefHeight="45" prefWidth="250" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="   📦  Produits" />
                <Button alignment="CENTER_LEFT" disable="false" onAction="#navigateToConsulterStock" prefHeight="45" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px; -fx-background-radius: 10; -fx-cursor: hand;" text="   📦  Stock" />
            </VBox>
            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />
            <VBox spacing="12" style="-fx-padding: 20 15;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="📦 STATISTIQUES" />
                <VBox spacing="8" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane prefHeight="45" prefWidth="45" style="-fx-background-color: linear-gradient(to bottom right, #f59e0b, #d97706); -fx-background-radius: 12;">
                            <Label style="-fx-font-size: 20px;" text="📦" />
                        </StackPane>
                        <VBox spacing="2">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Total Produits" />
                            <Label fx:id="lblTotalProduits" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
        <VBox alignment="CENTER" prefHeight="598.0" prefWidth="842.0" spacing="20" style="-fx-padding: 40;">
            <AnchorPane prefHeight="72.0" prefWidth="762.0">
                <children>
                    <Label layoutX="33.0" layoutY="25.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Liste des Produits" />
                    <Button layoutX="617.0" layoutY="87.0" onAction="#add" text="➕ Nouveau Produit" styleClass="action-button" />
                  <!-- Barre de recherche -->
                  <HBox alignment="CENTER_LEFT" layoutX="33.0" layoutY="44.0" prefHeight="86.0" prefWidth="494.0" spacing="10" style="-fx-padding: 0 0 10 0;">
                      <ComboBox fx:id="comboCritere" prefHeight="29.0" prefWidth="169.0" promptText="Critère de recherche" />
                      <TextField fx:id="txtValeurRecherche" prefWidth="200" promptText="Valeur à rechercher" />
                      <Button onAction="#rechercherProduit" text="🔍Rechercher" styleClass="search-button" />
                  </HBox>
                </children>
            </AnchorPane>
            <TableView fx:id="tableProduits" prefHeight="447.0" prefWidth="778.0">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                    <TableColumn fx:id="colNom" prefWidth="150" text="Nom" />
                    <TableColumn fx:id="colType" prefWidth="100" text="Type" />
                    <TableColumn fx:id="colUnite" prefWidth="100" text="Unité" />
                    <TableColumn fx:id="colPrixUnitaire" prefWidth="100" text="Prix unitaire" />
                </columns>
            </TableView>
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
                <children>
                    <Button layoutX="14.0" layoutY="14.0" onAction="#update" text="✏️ Modifier" styleClass="action-button" />
                    <Button layoutX="127.0" layoutY="14.0" onAction="#delete" text="🗑️ Supprimer" />
                    <Button fx:id="btnExportPDFProduit" layoutX="656.0" layoutY="14.0" onAction="#exporterPDFProduit" text="📄 Exporter PDF" styleClass="pdf-button" />
                </children>
            </AnchorPane>
        </VBox>
    </HBox>
</AnchorPane>
