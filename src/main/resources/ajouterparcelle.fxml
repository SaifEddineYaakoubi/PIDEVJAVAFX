<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.web.WebView?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.AjouterParcelleController"
            prefHeight="800.0" prefWidth="1150.0"
            style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);">

    <!-- Carte du formulaire -->
    <HBox spacing="20"
          AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- ======== PARTIE GAUCHE : Formulaire ======== -->
        <VBox alignment="CENTER" spacing="20" prefWidth="520" minWidth="500"
              style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 35;">

            <!-- En-tête avec icône -->
            <VBox alignment="CENTER" spacing="6">
                <StackPane prefWidth="70" prefHeight="70"
                           style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 35;">
                    <Label text="🌱" style="-fx-font-size: 35px;"/>
                </StackPane>
                <Label text="Nouvelle Parcelle" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <Label text="Ajoutez une nouvelle parcelle à votre exploitation" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="15">
                <!-- Nom -->
                <VBox spacing="5">
                    <Label text="📝 Nom de la parcelle" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="tfNom" promptText="Ex: Parcelle Nord" prefHeight="42"
                               style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Superficie -->
                <VBox spacing="5">
                    <Label text="📐 Superficie (m²)" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="tfSuperficie" promptText="Ex: 1500.5" prefHeight="42"
                               style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Localisation avec recherche OpenStreetMap -->
                <VBox spacing="5">
                    <Label text="📍 Localisation (recherche OpenStreetMap)" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <HBox spacing="8">
                        <TextField fx:id="tfLocalisation" promptText="🔍 Tapez une adresse, ville..." prefHeight="42" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                        <Button fx:id="btnSearchMap" text="🗺️" onAction="#rechercherSurCarte" prefWidth="45" prefHeight="42"
                                style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 10;"/>
                    </HBox>
                    <!-- Liste de suggestions (auto-complétion) -->
                    <ListView fx:id="lvSuggestions" prefHeight="0" visible="false" managed="false"
                              style="-fx-background-color: white; -fx-border-color: #667eea; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 11px;"/>
                    <!-- Coordonnées GPS -->
                    <Label fx:id="lblCoordinates" text="" style="-fx-font-size: 11px; -fx-text-fill: #667eea; -fx-font-weight: bold;"/>
                </VBox>

                <!-- État -->
                <VBox spacing="5">
                    <Label text="🏷️ État de la parcelle" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cbEtat" promptText="Sélectionner un état" prefHeight="42" maxWidth="1.7976931348623157E308"
                              style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

            <!-- Messages -->
            <VBox alignment="CENTER" spacing="4" minHeight="35">
                <Label fx:id="lblError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="450"/>
                <Label fx:id="lblSuccess" style="-fx-text-fill: #38a169; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Boutons -->
            <HBox spacing="15" alignment="CENTER">
                <Button fx:id="btnAjouter" text="✓ Enregistrer" onAction="#ajouterParcelle" prefWidth="170" prefHeight="48" HBox.hgrow="ALWAYS" maxWidth="200"
                        style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22; -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.5), 15, 0, 0, 5);"/>
                <Button fx:id="btnReset" text="🔄 Réinitialiser" onAction="#resetForm" prefWidth="160" prefHeight="48" HBox.hgrow="ALWAYS" maxWidth="190"
                        style="-fx-background-color: linear-gradient(to right, #11998e, #38ef7d); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22; -fx-effect: dropshadow(gaussian, rgba(17,153,142,0.4), 12, 0, 0, 4);"/>
                <Button fx:id="btnAnnuler" text="✗ Fermer" onAction="#fermerFenetre" prefWidth="140" prefHeight="48" HBox.hgrow="ALWAYS" maxWidth="170"
                        style="-fx-background-color: linear-gradient(to right, #bdc3c7, #95a5a6); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22; -fx-effect: dropshadow(gaussian, rgba(149,165,166,0.4), 12, 0, 0, 4);"/>
            </HBox>
        </VBox>

        <!-- ======== PARTIE DROITE : Carte OpenStreetMap ======== -->
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 15;">

            <!-- Titre de la carte -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-background-radius: 12; -fx-padding: 12 20;">
                <Label text="🗺️" style="-fx-font-size: 22px;"/>
                <VBox spacing="2">
                    <Label text="Carte OpenStreetMap" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Sélectionnez la localisation de votre parcelle" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>
            </HBox>

            <!-- WebView pour afficher la carte -->
            <WebView fx:id="webViewMap" VBox.vgrow="ALWAYS"
                     style="-fx-border-color: #e2e8f0; -fx-border-radius: 12;"/>

            <!-- Info -->
            <HBox spacing="8" alignment="CENTER" style="-fx-background-color: #ebf8ff; -fx-padding: 10 15; -fx-background-radius: 10;">
                <Label text="💡" style="-fx-font-size: 14px;"/>
                <Label text="Tapez une adresse pour voir la localisation sur la carte" style="-fx-font-size: 11px; -fx-text-fill: #2b6cb0;" wrapText="true"/>
            </HBox>
        </VBox>

    </HBox>

</AnchorPane>
