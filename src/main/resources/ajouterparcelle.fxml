<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.AjouterParcelleController"
            prefHeight="500.0" prefWidth="650.0" style="-fx-background-color: linear-gradient(to bottom right, #E8F5E9, #C8E6C9);">

    <!-- Carte du formulaire -->
    <VBox alignment="CENTER" spacing="20" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.bottomAnchor="20"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5); -fx-padding: 30;">

        <!-- Icône et Titre -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="🌱" style="-fx-font-size: 42px;"/>
            <Label text="Nouvelle Parcelle" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Label text="Remplissez les informations ci-dessous" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
        </VBox>

        <!-- Formulaire -->
        <GridPane hgap="15" vgap="15" alignment="CENTER">
            <!-- Nom -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="📝 Nom de la parcelle" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <TextField fx:id="tfNom" promptText="Ex: Parcelle Nord" prefWidth="270" prefHeight="38"
                           style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Superficie -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <Label text="📐 Superficie (m²)" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <TextField fx:id="tfSuperficie" promptText="Ex: 1500.5" prefWidth="270" prefHeight="38"
                           style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Localisation -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="📍 Localisation" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <TextField fx:id="tfLocalisation" promptText="Adresse ou coordonnées GPS" prefWidth="270" prefHeight="38"
                           style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>

            <!-- État -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <Label text="🏷️ État de la parcelle" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbEtat" promptText="Sélectionner un état" prefWidth="270" prefHeight="38"
                          style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-font-size: 13px;"/>
            </VBox>
        </GridPane>
        
        <!-- Messages -->
        <VBox alignment="CENTER" spacing="3">
            <Label fx:id="lblError" style="-fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="500"/>
            <Label fx:id="lblSuccess" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="btnAjouter" text="✓ Enregistrer" onAction="#ajouterParcelle" prefWidth="160" prefHeight="40"
                    style="-fx-background-color: linear-gradient(to bottom, #4CAF50, #388E3C); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button fx:id="btnReset" text="🔄 Réinitialiser" onAction="#resetForm" prefWidth="140" prefHeight="40"
                    style="-fx-background-color: linear-gradient(to bottom, #FF9800, #F57C00); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button fx:id="btnAnnuler" text="✗ Fermer" onAction="#fermerFenetre" prefWidth="120" prefHeight="40"
                    style="-fx-background-color: linear-gradient(to bottom, #9E9E9E, #757575); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
        </HBox>

        <!-- Indication -->
        <Label text="💡 Tous les champs sont obligatoires" style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E;"/>

    </VBox>
    
</AnchorPane>
