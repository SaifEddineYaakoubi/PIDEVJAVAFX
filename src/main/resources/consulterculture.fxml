<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ConsulterCultureController"
            prefHeight="550.0" prefWidth="950.0" style="-fx-background-color: #FFFFFF;">

    <!-- Barre de navigation -->
    <HBox spacing="10" style="-fx-background-color: #2E7D32; -fx-padding: 10;" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Button text="📋 Liste Parcelles" onAction="#navigateToConsulterParcelle"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="➕ Ajouter Parcelle" onAction="#navigateToAjouterParcelle"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="📋 Liste Cultures"
                style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="➕ Ajouter Culture" onAction="#navigateToAjouterCulture"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <VBox spacing="15" AnchorPane.topAnchor="60" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- Titre et Recherche -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="🌾 Liste des Cultures" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="tfRecherche" promptText="Rechercher par type ou état..." prefWidth="280"
                           style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5; -fx-padding: 8;"/>
            </HBox>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="tableViewCultures" VBox.vgrow="ALWAYS" style="-fx-border-color: #8D6E63; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="colType" text="Type de Culture" prefWidth="180">
                    <cellValueFactory><PropertyValueFactory property="typeCulture"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colDatePlantation" text="Date Plantation" prefWidth="130">
                    <cellValueFactory><PropertyValueFactory property="datePlantation"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colDateRecolte" text="Date Récolte Prévue" prefWidth="150">
                    <cellValueFactory><PropertyValueFactory property="dateRecoltePrevue"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colEtat" text="État Croissance" prefWidth="140">
                    <cellValueFactory><PropertyValueFactory property="etatCroissance"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colParcelle" text="Parcelle" prefWidth="150">
                    <cellValueFactory><PropertyValueFactory property="nomParcelle"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER">
            <Button text="🔄 Rafraîchir" onAction="#rafraichirListe"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Button text="✏️ Modifier" onAction="#modifierCulture"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Button text="🗑️ Supprimer" onAction="#supprimerCulture"
                    style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Label de message -->
        <Label fx:id="lblMessage" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

    </VBox>

</AnchorPane>
