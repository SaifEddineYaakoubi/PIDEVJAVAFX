<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ConsulterCultureController"
            prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom right, #fef9f3, #fdf2e9);">

    <!-- ============ BARRE DE NAVIGATION MODERNE ============ -->
    <HBox spacing="20" alignment="CENTER_LEFT"
          style="-fx-background-color: linear-gradient(to right, #8B4513, #A0522D, #CD853F); -fx-padding: 18 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 20, 0, 0, 6);"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Logo et Titre -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="🌾" style="-fx-font-size: 28px;"/>
            <VBox spacing="0">
                <Label text="SMART FARM" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Gestion Agricole Intelligente" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);"/>
            </VBox>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Navigation -->
        <HBox spacing="8" alignment="CENTER">
            <Button text="🌱 Parcelles" onAction="#navigateToConsulterParcelle"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 25; -fx-padding: 12 28; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 25;"/>
            <Button text="🌾 Cultures"
                    style="-fx-background-color: rgba(255,255,255,0.95); -fx-text-fill: #8B4513; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 25; -fx-padding: 12 28; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 3);"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Date/Heure -->
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label fx:id="lblDateTime" text="" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label text="Suivi des cultures" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px;"/>
        </VBox>
    </HBox>

    <!-- ============ CONTENU PRINCIPAL ============ -->
    <VBox spacing="20" AnchorPane.topAnchor="85" AnchorPane.leftAnchor="25" AnchorPane.rightAnchor="25" AnchorPane.bottomAnchor="20">

        <!-- ============ CARTES DE STATISTIQUES ============ -->
        <HBox spacing="15" alignment="CENTER">

            <!-- Total Cultures -->
            <VBox alignment="CENTER" spacing="8" prefWidth="190" prefHeight="115"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 18;">
                <HBox spacing="10" alignment="CENTER">
                    <StackPane prefWidth="45" prefHeight="45" style="-fx-background-color: linear-gradient(to bottom right, #f5af19, #f12711); -fx-background-radius: 12;">
                        <Label text="🌾" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Total" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;"/>
                        <Label fx:id="lblTotalCultures" text="0" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Germination -->
            <VBox alignment="CENTER" spacing="6" prefWidth="145" prefHeight="115"
                  style="-fx-background-color: linear-gradient(to bottom right, #e8f5e9, #c8e6c9); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 15;">
                <Label text="🌱" style="-fx-font-size: 26px;"/>
                <Label fx:id="lblGermination" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                <Label text="Germination" style="-fx-font-size: 11px; -fx-text-fill: #1b5e20; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Croissance -->
            <VBox alignment="CENTER" spacing="6" prefWidth="145" prefHeight="115"
                  style="-fx-background-color: linear-gradient(to bottom right, #e3f2fd, #bbdefb); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 15;">
                <Label text="🌿" style="-fx-font-size: 26px;"/>
                <Label fx:id="lblCroissance" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Label text="Croissance" style="-fx-font-size: 11px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Floraison -->
            <VBox alignment="CENTER" spacing="6" prefWidth="145" prefHeight="115"
                  style="-fx-background-color: linear-gradient(to bottom right, #fce4ec, #f8bbd9); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 15;">
                <Label text="🌸" style="-fx-font-size: 26px;"/>
                <Label fx:id="lblFloraison" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #c2185b;"/>
                <Label text="Floraison" style="-fx-font-size: 11px; -fx-text-fill: #880e4f; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Maturité -->
            <VBox alignment="CENTER" spacing="6" prefWidth="145" prefHeight="115"
                  style="-fx-background-color: linear-gradient(to bottom right, #fff3e0, #ffe0b2); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 15;">
                <Label text="🌻" style="-fx-font-size: 26px;"/>
                <Label fx:id="lblMaturite" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ef6c00;"/>
                <Label text="Maturité" style="-fx-font-size: 11px; -fx-text-fill: #e65100; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Récolte Proche -->
            <VBox alignment="CENTER" spacing="6" prefWidth="160" prefHeight="115"
                  style="-fx-background-color: linear-gradient(to bottom right, #ffebee, #ffcdd2); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 15;">
                <Label text="⏰" style="-fx-font-size: 26px;"/>
                <Label fx:id="lblRecolteProche" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
                <Label text="Récolte &lt; 7j" style="-fx-font-size: 11px; -fx-text-fill: #b71c1c; -fx-font-weight: bold;"/>
            </VBox>

        </HBox>

        <!-- ============ SECTION LISTE ============ -->
        <VBox spacing="15" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5);">

            <!-- En-tête avec recherche -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="3">
                    <Label text="🌾 Liste des Cultures" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8B4513;"/>
                    <Label text="Suivez la croissance de vos cultures" style="-fx-font-size: 12px; -fx-text-fill: #a0aec0;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Filtres et Recherche -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="cbFiltreEtat" promptText="🏷️ État" prefWidth="130" prefHeight="38"
                              style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="cbFiltreParcelle" promptText="📍 Parcelle" prefWidth="140" prefHeight="38"
                              style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 12px;"/>

                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #faf5f0; -fx-background-radius: 10; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-padding: 0 12;">
                        <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #a0aec0;"/>
                        <TextField fx:id="tfRecherche" promptText="Rechercher..." prefWidth="180" prefHeight="38"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 12px;"/>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="tableViewCultures" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12;">
                <columns>
                    <TableColumn fx:id="colType" text="🌱 Type de Culture" prefWidth="180">
                        <cellValueFactory><PropertyValueFactory property="typeCulture"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colDatePlantation" text="📅 Plantation" prefWidth="115">
                        <cellValueFactory><PropertyValueFactory property="datePlantation"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colDateRecolte" text="📅 Récolte Prévue" prefWidth="125">
                        <cellValueFactory><PropertyValueFactory property="dateRecoltePrevue"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colJoursRestants" text="⏱️ Jours" prefWidth="90"/>
                    <TableColumn fx:id="colEtat" text="🏷️ État" prefWidth="130">
                        <cellValueFactory><PropertyValueFactory property="etatCroissance"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colParcelle" text="📍 Parcelle" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="nomParcelle"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>

            <!-- Boutons d'action -->
            <HBox spacing="12" alignment="CENTER">
                <Button text="➕ Nouvelle Culture" onAction="#navigateToAjouterCulture" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #f5af19, #f12711); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 28; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(241,39,17,0.4), 12, 0, 0, 4);"/>

                <Button text="🔄 Rafraîchir" onAction="#rafraichirListe" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #56ab2f, #a8e063); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 28; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(86,171,47,0.4), 12, 0, 0, 4);"/>

                <Button fx:id="btnModifier" text="✏️ Modifier" onAction="#modifierCulture" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #c94b4b, #4b134f); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 28; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(201,75,75,0.4), 12, 0, 0, 4);"/>

                <Button fx:id="btnSupprimer" text="🗑️ Supprimer" onAction="#supprimerCulture" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #cb2d3e, #ef473a); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 28; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(239,71,58,0.4), 12, 0, 0, 4);"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="📄 Exporter PDF" onAction="#exporterListe" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #654ea3, #eaafc8); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 28; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(101,78,163,0.4), 12, 0, 0, 4);"/>
            </HBox>
        </VBox>

        <!-- ============ BARRE DE STATUT ============ -->
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(to right, #faf5f0, #f5ebe0); -fx-padding: 15 25; -fx-background-radius: 15; -fx-border-color: #ddd0c8; -fx-border-radius: 15;">
            <Label text="🌿" style="-fx-font-size: 16px;"/>
            <Label fx:id="lblMessage" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblResultats" text="Affichage: 0 sur 0" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
        </HBox>

    </VBox>

</AnchorPane>
