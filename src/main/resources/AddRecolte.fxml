<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.AddRecolteController"
            stylesheets="@smartfarm.css">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="navbar">
            <Label text="🌱 Smart Farm" styleClass="navbar-brand"/>
            <Button text="Dashboard" styleClass="nav-button"/>
            <Button text="Récoltes" styleClass="nav-button-active"/>
        </HBox>
    </top>

    <!-- FORM CENTER -->
    <center>
        <StackPane>
            <VBox spacing="20" styleClass="form-card" maxWidth="450">

                <Label text="Ajouter une Récolte" styleClass="form-title"/>
                <Label text="Remplissez les informations ci-dessous"
                       styleClass="form-subtitle"/>

                <!-- Nom Culture -->
                <VBox spacing="5">
                    <Label text="Nom de la Culture" styleClass="form-label"/>
                    <TextField fx:id="txtCulture"
                               promptText="Ex: Blé"
                               styleClass="text-field-modern"/>
                </VBox>

                <!-- Quantité -->
                <VBox spacing="5">
                    <Label text="Quantité (Kg)" styleClass="form-label"/>
                    <TextField fx:id="txtQuantite"
                               promptText="Ex: 500"
                               styleClass="text-field-modern"/>
                </VBox>

                <!-- Date -->
                <VBox spacing="5">
                    <Label text="Date de Récolte" styleClass="form-label"/>
                    <DatePicker fx:id="dateRecolte"
                                styleClass="date-picker-modern"/>
                </VBox>

                <!-- Saison -->
                <VBox spacing="5">
                    <Label text="Saison" styleClass="form-label"/>
                    <ComboBox fx:id="comboSaison"
                              styleClass="combo-box-modern"/>
                </VBox>

                <!-- Buttons -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="Enregistrer"
                            fx:id="btnSave"
                            styleClass="btn-success"/>
                    <Button text="Annuler"
                            styleClass="btn-secondary"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
