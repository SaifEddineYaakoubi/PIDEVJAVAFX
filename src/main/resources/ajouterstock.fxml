<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="580.0" prefWidth="700.0"
            style="-fx-background-color: linear-gradient(to bottom right, #a9744f, #6e4b2a);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.pidev.controllers.Stock.AjouterStockController">

    <VBox alignment="CENTER" spacing="25"
          style="-fx-background-color: #f7efe6;
                 -fx-background-radius: 30;
                 -fx-effect: dropshadow(gaussian, rgba(80,60,30,0.25), 30, 0, 0, 10);
                 -fx-padding: 40;"
          AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="40"
          AnchorPane.rightAnchor="40"
          AnchorPane.topAnchor="30">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8">
            <StackPane prefHeight="80" prefWidth="80"
                       style="-fx-background-color: linear-gradient(to bottom right, #a9744f, #6e4b2a);
                              -fx-background-radius: 40;">
                <Label text="📦" style="-fx-font-size: 38px;"/>
            </StackPane>

            <Label text="Nouveau Stock"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #6e4b2a;"/>

            <Label text="Ajoutez une nouvelle entrée de stock"
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #a9744f;"/>
        </VBox>

        <!-- Formulaire -->
        <GridPane alignment="CENTER" hgap="20" vgap="18">

            <!-- Produit -->
            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="📦 Produit associé"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6e4b2a;
                              -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbProduit"
                          prefHeight="45" prefWidth="280"
                          promptText="Sélectionner un produit"
                          style="-fx-background-color: #f3e5d0;
                                 -fx-border-color: #a9744f;
                                 -fx-border-radius: 12;
                                 -fx-background-radius: 12;
                                 -fx-padding: 5 10;
                                 -fx-font-size: 14px;
                                 -fx-text-fill: #6e4b2a;"/>
            </VBox>

            <!-- Quantité -->
            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="📦 Quantité"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6e4b2a;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="tfQuantite"
                           prefHeight="45" prefWidth="280"
                           promptText="Ex: 100"
                           style="-fx-background-color: #f3e5d0;
                                  -fx-border-color: #a9744f;
                                  -fx-border-radius: 12;
                                  -fx-background-radius: 12;
                                  -fx-padding: 10 15;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #6e4b2a;"/>
            </VBox>

            <!-- Date entrée -->
            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="📅 Date d'entrée"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6e4b2a;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="tfDateEntree"
                           editable="false"
                           prefHeight="45" prefWidth="280"
                           style="-fx-background-color: #f3e5d0;
                                  -fx-border-color: #a9744f;
                                  -fx-border-radius: 12;
                                  -fx-background-radius: 12;
                                  -fx-padding: 10 15;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #6e4b2a;"/>
            </VBox>

            <!-- Date sortie -->
            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="📅 Date de sortie"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #6e4b2a;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="tfDateExpiration"
                           prefHeight="45" prefWidth="280"
                           promptText="AAAA-MM-JJ"
                           style="-fx-background-color: #f3e5d0;
                                  -fx-border-color: #a9744f;
                                  -fx-border-radius: 12;
                                  -fx-background-radius: 12;
                                  -fx-padding: 10 15;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #6e4b2a;"/>
            </VBox>

            <columnConstraints>
                <ColumnConstraints />
                <ColumnConstraints />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>

        </GridPane>

        <!-- Bouton -->
        <Button fx:id="adds"
                text="✓ Enregistrer"
                onAction="#add"
                style="-fx-background-color: #a9744f;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 10;
                       -fx-padding: 10 30;"/>

    </VBox>
</AnchorPane>
