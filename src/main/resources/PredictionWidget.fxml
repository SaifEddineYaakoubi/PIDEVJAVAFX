<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pidev.controllers.PredictionWidgetController"
      spacing="20"
      style="-fx-background-color: white; -fx-border-color: #4CAF50; -fx-border-width: 2; -fx-background-radius: 15; -fx-padding: 20;">

    <HBox spacing="10" style="-fx-alignment: CENTER_LEFT;">
        <Label text="🤖 Prédictions" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2d5016;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh" text="🔄 Rafraîchir"
                style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-border-radius: 5;"/>
    </HBox>

    <Separator/>

    <!-- Conteneur pour les cartes de prédiction -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-control-inner-background: white;">
        <GridPane fx:id="predictionsGrid" hgap="15" vgap="15">
            <padding>
                <Insets top="0" right="10" bottom="0" left="0"/>
            </padding>
        </GridPane>
    </ScrollPane>

</VBox>

