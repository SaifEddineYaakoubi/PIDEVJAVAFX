<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.cultures.ModifierCultureController"
            prefHeight="650.0" prefWidth="720.0"
            style="-fx-background-color: linear-gradient(to bottom right, #c94b4b, #4b134f);">

    <!-- Carte du formulaire -->
    <VBox alignment="CENTER" spacing="18"
          AnchorPane.topAnchor="25" AnchorPane.leftAnchor="35" AnchorPane.rightAnchor="35" AnchorPane.bottomAnchor="25"
          style="-fx-background-color: white; -fx-background-radius: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 30;">

        <!-- En-tête avec icône -->
        <VBox alignment="CENTER" spacing="6">
            <StackPane prefWidth="70" prefHeight="70"
                       style="-fx-background-color: linear-gradient(to bottom right, #c94b4b, #4b134f); -fx-background-radius: 35;">
                <Label text="✏️" style="-fx-font-size: 35px;"/>
            </StackPane>
            <Label text="Modifier la Culture" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
            <Label fx:id="lblInfo" text="" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
        </VBox>

        <!-- Formulaire -->
        <GridPane hgap="18" vgap="14" alignment="CENTER">
            <!-- Type de culture -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="🌱 Type de culture" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <TextField fx:id="tfTypeCulture" promptText="Ex: Blé, Maïs, Tomates..." prefWidth="300" prefHeight="40"
                           style="-fx-background-color: #faf0f4; -fx-border-color: #e8b4c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 15; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Parcelle -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <Label text="📍 Parcelle associée" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbParcelle" promptText="Sélectionner une parcelle" prefWidth="300" prefHeight="40"
                          style="-fx-background-color: #faf0f4; -fx-border-color: #e8b4c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Date de plantation -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="📅 Date de plantation" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDatePlantation" promptText="Sélectionner une date" prefWidth="300" prefHeight="40"
                            style="-fx-background-color: #faf0f4; -fx-border-color: #e8b4c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Date de récolte prévue -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <Label text="📆 Date récolte prévue" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDateRecoltePrevue" promptText="Sélectionner une date" prefWidth="300" prefHeight="40"
                            style="-fx-background-color: #faf0f4; -fx-border-color: #e8b4c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- État de croissance -->
            <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" alignment="CENTER">
                <Label text="🏷️ État de croissance" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <HBox spacing="18" alignment="CENTER" style="-fx-background-color: #faf0f4; -fx-padding: 12 22; -fx-background-radius: 12;">
                    <RadioButton fx:id="rbGermination" text="🌱 Germination" style="-fx-font-size: 11px; -fx-text-fill: #2e7d32;"/>
                    <RadioButton fx:id="rbCroissance" text="🌿 Croissance" style="-fx-font-size: 11px; -fx-text-fill: #1565c0;"/>
                    <RadioButton fx:id="rbFloraison" text="🌸 Floraison" style="-fx-font-size: 11px; -fx-text-fill: #c2185b;"/>
                    <RadioButton fx:id="rbMaturite" text="🌻 Maturité" style="-fx-font-size: 11px; -fx-text-fill: #ef6c00;"/>
                </HBox>
            </VBox>
        </GridPane>

        <!-- Aperçu des jours -->
        <HBox spacing="12" alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #f3e5f5, #e1bee7); -fx-padding: 12 25; -fx-background-radius: 12;">
            <Label text="⏱️" style="-fx-font-size: 18px;"/>
            <Label text="Durée estimée:" style="-fx-font-size: 13px; -fx-text-fill: #7b1fa2; -fx-font-weight: bold;"/>
            <Label fx:id="lblDureeEstimee" text="-- jours" style="-fx-font-size: 15px; -fx-text-fill: #4a148c; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Messages -->
        <VBox alignment="CENTER" spacing="4" minHeight="32">
            <Label fx:id="lblError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="580"/>
            <Label fx:id="lblSuccess" style="-fx-text-fill: #38a169; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="btnModifier" text="✓ Enregistrer" onAction="#modifierCulture" prefWidth="170" prefHeight="46"
                    style="-fx-background-color: linear-gradient(to right, #c94b4b, #4b134f); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(201,75,75,0.5), 15, 0, 0, 5);"/>
            <Button fx:id="btnReset" text="🔄 Réinitialiser" onAction="#resetForm" prefWidth="155" prefHeight="46"
                    style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.4), 12, 0, 0, 4);"/>
            <Button fx:id="btnAnnuler" text="✗ Annuler" onAction="#fermerFenetre" prefWidth="125" prefHeight="46"
                    style="-fx-background-color: linear-gradient(to right, #bdc3c7, #95a5a6); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(149,165,166,0.4), 12, 0, 0, 4);"/>
        </HBox>

        <!-- Indication -->
        <HBox spacing="8" alignment="CENTER" style="-fx-background-color: #faf0f4; -fx-padding: 10 18; -fx-background-radius: 10;">
            <Label text="💡" style="-fx-font-size: 14px;"/>
            <Label text="Les modifications seront appliquées immédiatement" style="-fx-font-size: 11px; -fx-text-fill: #880e4f;"/>
        </HBox>

    </VBox>

</AnchorPane>
