<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.web.WebView?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.parcelles.ModifierParcelleController"
            prefHeight="750.0" prefWidth="950.0"
            style="-fx-background-color: linear-gradient(to bottom right, #f093fb, #f5576c);">

    <HBox spacing="20"
          AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- ======== PARTIE GAUCHE : Formulaire ======== -->
        <VBox alignment="CENTER" spacing="20" prefWidth="450"
              style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 30;">

            <!-- En-tête -->
            <VBox alignment="CENTER" spacing="6">
                <StackPane prefWidth="70" prefHeight="70"
                           style="-fx-background-color: linear-gradient(to bottom right, #f093fb, #f5576c); -fx-background-radius: 35;">
                    <Label text="✏️" style="-fx-font-size: 35px;"/>
                </StackPane>
                <Label text="Modifier la Parcelle" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <Label fx:id="lblInfo" text="" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="15">
                <VBox spacing="5">
                    <Label text="📝 Nom de la parcelle" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="tfNom" promptText="Ex: Parcelle Nord" prefHeight="42"
                               style="-fx-background-color: #fdf2f8; -fx-border-color: #f8b4d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="📐 Superficie (m²)" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <TextField fx:id="tfSuperficie" promptText="Ex: 1500.5" prefHeight="42"
                               style="-fx-background-color: #fdf2f8; -fx-border-color: #f8b4d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Localisation avec OpenStreetMap -->
                <VBox spacing="5">
                    <Label text="📍 Localisation (recherche OpenStreetMap)" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <HBox spacing="8">
                        <TextField fx:id="tfLocalisation" promptText="🔍 Tapez une adresse, ville..." prefHeight="42" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #fdf2f8; -fx-border-color: #f8b4d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
                        <Button text="🗺️" onAction="#rechercherSurCarte" prefWidth="45" prefHeight="42"
                                style="-fx-background-color: linear-gradient(to right, #f093fb, #f5576c); -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 10;"/>
                    </HBox>
                    <ListView fx:id="lvSuggestions" prefHeight="0" visible="false" managed="false"
                              style="-fx-background-color: white; -fx-border-color: #f5576c; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 11px;"/>
                    <Label fx:id="lblCoordinates" text="" style="-fx-font-size: 11px; -fx-text-fill: #f5576c; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="🏷️ État de la parcelle" style="-fx-font-size: 12px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cbEtat" promptText="Sélectionner un état" prefHeight="42" maxWidth="1.7976931348623157E308"
                              style="-fx-background-color: #fdf2f8; -fx-border-color: #f8b4d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

            <!-- Messages -->
            <VBox alignment="CENTER" spacing="4" minHeight="35">
                <Label fx:id="lblError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="380"/>
                <Label fx:id="lblSuccess" style="-fx-text-fill: #38a169; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Boutons -->
            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="btnModifier" text="✓ Enregistrer" onAction="#modifierParcelle" prefWidth="150" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #f093fb, #f5576c); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22;"/>
                <Button fx:id="btnReset" text="🔄 Reset" onAction="#resetForm" prefWidth="110" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22;"/>
                <Button fx:id="btnAnnuler" text="✗ Annuler" onAction="#fermerFenetre" prefWidth="110" prefHeight="45"
                        style="-fx-background-color: linear-gradient(to right, #bdc3c7, #95a5a6); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 22;"/>
            </HBox>
        </VBox>

        <!-- ======== PARTIE DROITE : Carte OpenStreetMap ======== -->
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 15;">

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #f093fb, #f5576c); -fx-background-radius: 12; -fx-padding: 12 20;">
                <Label text="🗺️" style="-fx-font-size: 22px;"/>
                <VBox spacing="2">
                    <Label text="Carte OpenStreetMap" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Localisation actuelle de la parcelle" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>
            </HBox>

            <WebView fx:id="webViewMap" VBox.vgrow="ALWAYS"/>

            <HBox spacing="8" alignment="CENTER" style="-fx-background-color: #fdf2f8; -fx-padding: 10 15; -fx-background-radius: 10;">
                <Label text="💡" style="-fx-font-size: 14px;"/>
                <Label text="Modifiez l'adresse pour mettre à jour la carte" style="-fx-font-size: 11px; -fx-text-fill: #9f1239;" wrapText="true"/>
            </HBox>
        </VBox>

    </HBox>

</AnchorPane>
