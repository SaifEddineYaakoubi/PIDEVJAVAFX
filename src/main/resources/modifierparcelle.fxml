<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ModifierParcelleController"
            prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #FFFFFF;">

    <!-- Barre de navigation -->
    <HBox spacing="10" style="-fx-background-color: #2E7D32; -fx-padding: 10;" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Button text="📋 Liste Parcelles" onAction="#navigateToConsulterParcelle"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="➕ Ajouter Parcelle" onAction="#navigateToAjouterParcelle"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="📋 Liste Cultures" onAction="#navigateToConsulterCulture"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="➕ Ajouter Culture" onAction="#navigateToAjouterCulture"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <VBox alignment="CENTER" spacing="20" AnchorPane.topAnchor="70" AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50">
        
        <!-- Titre -->
        <Label text="✏️ Modifier la Parcelle" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #FF9800;">
            <padding>
                <Insets bottom="20"/>
            </padding>
        </Label>
        
        <!-- Formulaire -->
        <GridPane hgap="15" vgap="18" alignment="CENTER">
            <!-- Nom -->
            <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <TextField fx:id="tfNom" promptText="Nom de la parcelle" prefWidth="300" GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5; -fx-padding: 8;"/>

            <!-- Superficie -->
            <Label text="Superficie (m²) :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <TextField fx:id="tfSuperficie" promptText="Ex: 1500.5" prefWidth="300" GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5; -fx-padding: 8;"/>

            <!-- Localisation -->
            <Label text="Localisation :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <TextField fx:id="tfLocalisation" promptText="Adresse ou coordonnées" prefWidth="300" GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5; -fx-padding: 8;"/>

            <!-- État -->
            <Label text="État :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-size: 14px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cbEtat" promptText="Sélectionner un état" prefWidth="300" GridPane.rowIndex="3" GridPane.columnIndex="1"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5;"/>
        </GridPane>
        
        <!-- Label d'erreur -->
        <Label fx:id="lblError" style="-fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="400"/>

        <!-- Label de succès -->
        <Label fx:id="lblSuccess" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;"/>

        <!-- Boutons -->
        <HBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="15"/>
            </padding>
            <Button fx:id="btnModifier" text="✓ Modifier" onAction="#modifierParcelle"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Button fx:id="btnAnnuler" text="↩ Retour" onAction="#retourListe"
                    style="-fx-background-color: #8D6E63; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-cursor: hand; -fx-background-radius: 5;"/>
        </HBox>
        
    </VBox>
    
</AnchorPane>
