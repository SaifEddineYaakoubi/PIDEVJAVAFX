<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.AddRendementController"
            stylesheets="@smartfarm.css">

<!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="navbar">
            <Label text="📊 Smart Farm - Rendements" styleClass="navbar-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour" fx:id="btnRetour" styleClass="nav-button"/>
        </HBox>
    </top>

    <!-- FORM CENTER -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <VBox spacing="20" styleClass="content-area" style="-fx-padding: 30;">

                <!-- HEADER -->
                <VBox spacing="10">
                    <Label text="Ajouter un Rendement" styleClass="section-title"/>
                    <Label text="Enregistrez un nouveau rendement avec les informations détaillées"
                           styleClass="form-subtitle"/>
                </VBox>

                <!-- FORM CONTAINER -->
                <VBox spacing="20" styleClass="card" style="-fx-padding: 25;">

                    <!-- ROW 1: Sélection Récolte -->
                    <VBox spacing="8">
                        <Label text="🌾 Récolte Associée *" styleClass="form-label"/>
                        <HBox spacing="10">
                            <ComboBox fx:id="comboRecolte"
                                      promptText="Sélectionnez une récolte..."
                                      HBox.hgrow="ALWAYS"
                                      styleClass="combo-box-modern"/>
                            <Button text="Rafraîchir"
                                    fx:id="btnRefresh"
                                    styleClass="button-secondary"
                                    style="-fx-padding: 10 20;"/>
                        </HBox>
                        <Label fx:id="lblRecolteInfo"
                               text="Aucune récolte sélectionnée"
                               styleClass="form-info"
                               style="-fx-text-fill: #999999; -fx-font-size: 12px;"/>
                    </VBox>

                    <!-- SEPARATOR -->
                    <Separator/>

                    <!-- ROW 2: Surface Exploitée -->
                    <VBox spacing="8">
                        <Label text="🌍 Surface Exploitée (ha) *" styleClass="form-label"/>
                        <TextField fx:id="txtSurface"
                                   promptText="Ex: 10.5"
                                   styleClass="text-field-modern"/>
                        <Label text="Minimum: 0.01 ha | Maximum: 10000 ha"
                               styleClass="form-help"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- ROW 3: Quantité Totale -->
                    <VBox spacing="8">
                        <Label text="📦 Quantité Totale (Kg) *" styleClass="form-label"/>
                        <TextField fx:id="txtQuantite"
                                   promptText="Ex: 500"
                                   styleClass="text-field-modern"/>
                        <Label text="La quantité maximale est de 1,000,000 Kg"
                               styleClass="form-help"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- ROW 4: Productivité (Calcul automatique) -->
                    <VBox spacing="8">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="⚡ Productivité (Kg/ha)" styleClass="form-label"/>
                            <CheckBox fx:id="chkAutoCalcul"
                                      text="Calculer automatiquement"
                                      selected="true"
                                      style="-fx-font-size: 12px;"/>
                        </HBox>
                        <TextField fx:id="txtProductivite"
                                   promptText="Sera calculée automatiquement"
                                   styleClass="text-field-modern"
                                   disable="true"/>
                        <Label text="Productivité = Quantité Totale / Surface Exploitée"
                               styleClass="form-help"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- ROW 5: Affichage du résultat du calcul -->
                    <VBox spacing="8" style="-fx-border-color: #4caf50; -fx-border-width: 1; -fx-padding: 15; -fx-border-radius: 8; -fx-background-color: #f1f8f4;">
                        <Label text="📊 Résumé du Rendement" styleClass="form-label" style="-fx-text-fill: #2e7d32;"/>
                        <GridPane hgap="20" vgap="10">
                            <Label text="Surface: " GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblResultSurface" text="-- ha" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label text="Quantité: " GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblResultQuantite" text="-- Kg" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Label text="Productivité: " GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblResultProductivite" text="-- Kg/ha" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #4caf50; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- ACTION BUTTONS -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                    <Button text="✓ Enregistrer"
                            fx:id="btnSave"
                            styleClass="button-primary"
                            style="-fx-padding: 12 30; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Button text="🔄 Réinitialiser"
                            fx:id="btnReset"
                            styleClass="button-secondary"
                            style="-fx-padding: 12 30; -fx-font-size: 14px;"/>
                    <Button text="✕ Fermer"
                            fx:id="btnCancel"
                            styleClass="button-secondary"
                            style="-fx-padding: 12 30; -fx-font-size: 14px;"/>
                </HBox>

                <!-- INFO MESSAGE -->
                <VBox spacing="5" style="-fx-border-color: #fff3cd; -fx-border-width: 1; -fx-padding: 15; -fx-border-radius: 8; -fx-background-color: #fffbea;">
                    <Label text="ℹ️ Informations" style="-fx-font-weight: bold; -fx-text-fill: #856404;"/>
                    <Label text="• Les champs marqués avec * sont obligatoires"
                           style="-fx-text-fill: #856404; -fx-font-size: 12px; -fx-wrap-text: true;"/>
                    <Label text="• La productivité se calcule automatiquement: Quantité ÷ Surface"
                           style="-fx-text-fill: #856404; -fx-font-size: 12px; -fx-wrap-text: true;"/>
                    <Label text="• Vous pouvez désactiver le calcul automatique si vous connaissez déjà la productivité"
                           style="-fx-text-fill: #856404; -fx-font-size: 12px; -fx-wrap-text: true;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="status-bar" style="-fx-padding: 10 20;">
            <Label fx:id="lblStatus"
                   text="Prêt à enregistrer un nouveau rendement"
                   styleClass="status-label"
                   style="-fx-text-fill: #4caf50;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Rendements" style="-fx-text-fill: #666666;"/>
        </HBox>
    </bottom>

</BorderPane>

