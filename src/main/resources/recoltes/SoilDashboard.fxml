<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.pidev.controllers.recoltes.SoilDashboardController"
      spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">

    <!-- En-tête avec titre et statut -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="🪴 ANALYSE DU SOL" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2d5016;"/>
        <Circle fx:id="soilStatusCircle" radius="8" fill="#cccccc"/>
        <Label fx:id="soilStatusLabel" text="Chargement..." style="-fx-font-size: 11; -fx-text-fill: #666;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshSoilButton" text="🔄 Rafraîchir" style="-fx-font-size: 11; -fx-padding: 5;"/>
    </HBox>

    <Separator/>

    <!-- Contenu principal (GridPane 2x4) -->
    <GridPane fx:id="soilDataGrid" hgap="15" vgap="15" style="-fx-padding: 10;">
        <columnConstraints>
            <ColumnConstraints percentWidth="25.0" />
            <ColumnConstraints percentWidth="25.0" />
            <ColumnConstraints percentWidth="25.0" />
            <ColumnConstraints percentWidth="25.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="120"/>
            <RowConstraints minHeight="120"/>
        </rowConstraints>

        <!-- Ligne 1 -->
        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0"
              style="-fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🔬 pH" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="phValue" text="6.8" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a3d0a;"/>
            <Label fx:id="phCategory" text="Neutre ✅" style="-fx-font-size: 11; -fx-text-fill: #5cb85c; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0"
              style="-fx-border-color: #ffd699; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="📊 Azote (N)" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="nitrogenValue" text="120 mg/kg" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #d9534f;"/>
            <Label fx:id="nitrogenStatus" text="⚠️ Faible" style="-fx-font-size: 11; -fx-text-fill: #d9534f; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0"
              style="-fx-border-color: #b3d9b3; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="⚗️ Phosphore (P)" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="phosphorusValue" text="15 mg/kg" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #5cb85c;"/>
            <Label fx:id="phosphorusStatus" text="✓ Bon" style="-fx-font-size: 11; -fx-text-fill: #5cb85c; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="3" GridPane.rowIndex="0"
              style="-fx-border-color: #b3d9b3; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🌱 Potassium (K)" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="potassiumValue" text="200 mg/kg" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #5cb85c;"/>
            <Label fx:id="potassiumStatus" text="✅ Bon" style="-fx-font-size: 11; -fx-text-fill: #5cb85c; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Ligne 2 -->
        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1"
              style="-fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🏜️ Sable" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="sandValue" text="35%" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #d4a574;"/>
            <ProgressBar fx:id="sandProgress" progress="0.35" prefWidth="Infinity" prefHeight="8" style="-fx-accent: #d4a574;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1"
              style="-fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="💧 Limon" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="siltValue" text="45%" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #8b7355;"/>
            <ProgressBar fx:id="siltProgress" progress="0.45" prefWidth="Infinity" prefHeight="8" style="-fx-accent: #8b7355;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="1"
              style="-fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🧱 Argile" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="clayValue" text="20%" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #a9a9a9;"/>
            <ProgressBar fx:id="clayProgress" progress="0.20" prefWidth="Infinity" prefHeight="8" style="-fx-accent: #a9a9a9;"/>
        </VBox>

        <VBox spacing="8" GridPane.columnIndex="3" GridPane.rowIndex="1"
              style="-fx-border-color: #ffd699; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="🌾 Matière Organique" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2d5016;"/>
            <Label fx:id="organicCarbonValue" text="2.5%" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #d9534f;"/>
            <Label fx:id="organicStatus" text="⚠️ Faible" style="-fx-font-size: 11; -fx-text-fill: #d9534f; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

    <!-- Recommandations -->
    <VBox spacing="10" style="-fx-border-color: #d4edda; -fx-border-width: 2; -fx-padding: 15; -fx-background-color: #f8f9fa; -fx-border-radius: 5;">
        <Label text="📋 RECOMMANDATIONS" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #155724;"/>
        <Label fx:id="recommendationCrop" text="✅ Idéal pour Tomate, Blé, Maïs, Pomme terre"
               style="-fx-font-size: 11; -fx-text-fill: #155724; -fx-wrap-text: true;"/>
        <Label fx:id="textureRecommendation" text="✅ Texture idéale: Sable 35%, Limon 45%, Argile 20%"
               style="-fx-font-size: 11; -fx-text-fill: #155724; -fx-wrap-text: true;"/>
        <Separator/>
        <Label text="🔧 ACTIONS RECOMMANDÉES:" style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #155724;"/>
        <TextArea fx:id="fertilizationAdviceArea" wrapText="true" prefRowCount="4" editable="false"
                  style="-fx-font-size: 10; -fx-padding: 10; -fx-background-color: white;"/>
    </VBox>

</VBox>
