<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pidev.controllers.recoltes.DashboardDefaultController"
      stylesheets="@smartfarmm.css"
      style="-fx-padding: 30; -fx-background-color: transparent;">

    <!-- ========== BIENVENUE ========== -->
    <VBox spacing="8"
          style="-fx-background-color: linear-gradient(to right, #2E7D32, #4CAF50); -fx-background-radius: 18; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(46,125,50,0.3), 15, 0, 0, 5);">
        <Label fx:id="lblWelcome" text="👋 Bienvenue sur Smart Farm"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="lblWelcomeSub" text="Votre tableau de bord agricole intelligent"
               style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.85);"/>
    </VBox>

    <!-- ========== CARTES STATISTIQUES ========== -->
    <HBox spacing="20">
        <!-- Total Récoltes -->
        <VBox spacing="5" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 4); -fx-border-color: #4CAF50; -fx-border-width: 0 0 3 0; -fx-border-radius: 16;">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, #4CAF50, #2E7D32); -fx-background-radius: 14;">
                    <Label text="🌾" style="-fx-font-size: 24px;"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="Total Récoltes" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTotalRecoltes" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                </VBox>
            </HBox>
            <Label text="récoltes enregistrées" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Total Rendements -->
        <VBox spacing="5" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 4); -fx-border-color: #78350f; -fx-border-width: 0 0 3 0; -fx-border-radius: 16;">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, #b45309, #78350f); -fx-background-radius: 14;">
                    <Label text="📊" style="-fx-font-size: 24px;"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="Total Rendements" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTotalRendements" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #78350f;"/>
                </VBox>
            </HBox>
            <Label text="rendements enregistrés" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Surface Totale -->
        <VBox spacing="5" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 4); -fx-border-color: #f59e0b; -fx-border-width: 0 0 3 0; -fx-border-radius: 16;">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, #f59e0b, #d97706); -fx-background-radius: 14;">
                    <Label text="🌍" style="-fx-font-size: 24px;"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="Surface Totale" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblSurfaceTotale" text="0 ha" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
                </VBox>
            </HBox>
            <Label text="hectares exploités" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Parcelles -->
        <VBox spacing="5" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 4); -fx-border-color: #8b5cf6; -fx-border-width: 0 0 3 0; -fx-border-radius: 16;">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, #8b5cf6, #7c3aed); -fx-background-radius: 14;">
                    <Label text="🌱" style="-fx-font-size: 24px;"/>
                </StackPane>
                <VBox spacing="3">
                    <Label text="Parcelles" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="lblTotalParcelles" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                </VBox>
            </HBox>
            <Label text="parcelles actives" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- ========== ACCÈS RAPIDE ========== -->
    <VBox spacing="15"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 4);">
        <Label text="⚡ Accès Rapide" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <HBox spacing="15">
            <VBox fx:id="cardRecoltes" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #f0fdf4; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="🌾" style="-fx-font-size: 30px;"/>
                <Label text="Récoltes" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #166534;"/>
            </VBox>
            <VBox fx:id="cardRendements" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #fef3c7; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="📈" style="-fx-font-size: 30px;"/>
                <Label text="Rendements" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #78350f;"/>
            </VBox>
            <VBox fx:id="cardParcelles" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #ede9fe; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="🌱" style="-fx-font-size: 30px;"/>
                <Label text="Parcelles" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
            </VBox>
            <VBox fx:id="cardCultures" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #ecfdf5; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="🌿" style="-fx-font-size: 30px;"/>
                <Label text="Cultures" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #065f46;"/>
            </VBox>
            <VBox fx:id="cardSol" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #fff1f2; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="🪴" style="-fx-font-size: 30px;"/>
                <Label text="Analyse Sol" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #9f1239;"/>
            </VBox>
            <VBox fx:id="cardPredictions" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #f0f9ff; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="🤖" style="-fx-font-size: 30px;"/>
                <Label text="Prédictions IA" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
            </VBox>
            <VBox fx:id="cardArchive" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #faf5ff; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="📦" style="-fx-font-size: 30px;"/>
                <Label text="Archive" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6b21a8;"/>
            </VBox>
        </HBox>

        <!-- ACCÈS RAPIDE : Ventes & Clients -->
        <HBox spacing="15">
            <VBox fx:id="cardClients" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #eff6ff; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="👥" style="-fx-font-size: 30px;"/>
                <Label text="Clients" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
            </VBox>
            <VBox fx:id="cardVentes" alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS" prefHeight="100"
                  style="-fx-background-color: #fef9c3; -fx-background-radius: 14; -fx-padding: 15; -fx-cursor: hand;">
                <Label text="💰" style="-fx-font-size: 30px;"/>
                <Label text="Ventes" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #854d0e;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- ========== INFO RAPIDE ========== -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 15 22; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
        <Label text="💡" style="-fx-font-size: 16px;"/>
        <Label text="Utilisez la navigation à gauche pour accéder aux différents modules de gestion."
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
    </HBox>

</VBox>
