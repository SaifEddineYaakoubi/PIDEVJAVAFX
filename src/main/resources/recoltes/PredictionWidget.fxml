<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pidev.controllers.recoltes.PredictionController"
      spacing="20"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Titre et description -->
    <VBox spacing="10">
        <Label text="🤖 Prédictions de Rendement"
               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2d5016;"/>
        <Label text="Prédictions intelligentes basées sur vos données historiques de récolte"
               style="-fx-font-size: 14; -fx-text-fill: #666;"/>
        <Separator/>
    </VBox>

    <!-- Grid des prédictions -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-control-inner-background: #f5f5f5;">
        <GridPane fx:id="predictionsGrid"/>
    </ScrollPane>

</VBox>

