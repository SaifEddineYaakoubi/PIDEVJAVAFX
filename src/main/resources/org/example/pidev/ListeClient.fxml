<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.ClientController">

    <stylesheets>
        <URL value="@smartfarm.css" />
    </stylesheets>

    <children>
        <!-- HEADER SECTION -->
        <VBox spacing="5" styleClass="dashboard-header">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label styleClass="dashboard-title" text="👥 Gestion des Clients" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleAjouter" styleClass="btn-add" text="+ Nouveau Client" />
            </HBox>
            <Label styleClass="dashboard-subtitle" text="Gérez vos clients et leurs informations" />
        </VBox>

        <!-- SEARCH & FILTER SECTION -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="activities-section" style="-fx-padding: 20;">
            <Label styleClass="activity-title" text="Rechercher :" />
            <TextField fx:id="searchIdField" promptText="ID, Nom ou Email..." styleClass="text-field" HBox.hgrow="ALWAYS" />
            <Button onAction="#handleSearchById" styleClass="btn-edit" text="Chercher" />
            <Button onAction="#handleResetSearch" styleClass="btn-secondary" text="↻" />
        </HBox>

        <!-- TABLE VIEW SECTION -->
        <VBox VBox.vgrow="ALWAYS" styleClass="activities-section" style="-fx-padding: 15;">
            <TableView fx:id="clientTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150" />
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180" />
                    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120" />
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- ACTION BUTTONS SECTION -->
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="activities-section" style="-fx-padding: 15;">
            <Button onAction="#handleModifier" styleClass="btn-edit" text="✏️ Modifier" />
            <Button onAction="#handleSupprimer" styleClass="btn-delete" text="🗑️ Supprimer" />
            <Button onAction="#handleGenerateRemise" styleClass="sidebar-button-purple" style="-fx-pref-width: 150; -fx-pref-height: 40;" text="💎 Remise" />
            <Button onAction="#handleExportPDF" styleClass="sidebar-button-orange" style="-fx-pref-width: 150; -fx-pref-height: 40;" text="📄 PDF" />
        </HBox>
    </children>
</VBox>
