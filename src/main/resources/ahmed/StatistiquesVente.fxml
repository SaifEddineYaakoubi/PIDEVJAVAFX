<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ahmed.StatistiquesVenteController"
            style="-fx-background-color: #f4f7f6;">

    <!-- ============ SCROLLPANE WRAPPER - SCROLLABLE CONTENT ============ -->
    <ScrollPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                pannable="true">

        <!-- ============ MAIN CONTENT (Right) - MODERN LAYOUT ============ -->
        <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f4f7f6;" mouseTransparent="false">

        <!-- Header Card -->
        <VBox spacing="8" style="-fx-padding: 25; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);">
            <Label text="📊 Statistiques des Ventes" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
            <Label text="Analyse complète et détaillée de vos performances commerciales" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <!-- KPI Cards Row -->
        <HBox spacing="20" alignment="TOP_CENTER">
            <!-- KPI 1: Clients -->
            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 24; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-width: 0 0 0 4; -fx-border-color: #3498db; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="👥" style="-fx-font-size: 36px;"/>
                <Label text="Total Clients" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: normal;"/>
                <Label fx:id="totalClientsLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <Label text="Enregistrés" style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>
            </VBox>

            <!-- KPI 2: Ventes -->
            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 24; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-width: 0 0 0 4; -fx-border-color: #9b59b6; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="📈" style="-fx-font-size: 36px;"/>
                <Label text="Total Ventes" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: normal;"/>
                <Label fx:id="totalVentesLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <Label text="Transactions" style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>
            </VBox>

            <!-- KPI 3: Montant -->
            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 24; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-border-width: 0 0 0 4; -fx-border-color: #f39c12; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="💰" style="-fx-font-size: 36px;"/>
                <Label text="Montant Total" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: normal;"/>
                <Label fx:id="montantTotalLabel" text="0.00 TND" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <Label text="Revenus" style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>
            </VBox>
        </HBox>

        <!-- Chart Section Card -->
        <VBox spacing="15" style="-fx-padding: 28; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.1), 12, 0, 0, 3);" VBox.vgrow="ALWAYS">

            <!-- Chart Title -->
            <Label text="📊 Montant des Ventes par Client" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>

            <!-- BarChart -->
            <BarChart fx:id="barChart"
                      title=""
                      animated="true"
                      style="-fx-padding: 15; -fx-font-size: 12px; -fx-text-fill: #2c3e50;"
                      VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Client"
                                  style="-fx-text-fill: #2d5a27; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Montant (TND)"
                                style="-fx-text-fill: #2d5a27; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                </yAxis>
            </BarChart>
        </VBox>

        <!-- Action Buttons Card -->
        <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.08), 10, 0, 0, 2);">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Rafraîchir les Données"
                    onAction="#handleRefresh"
                    style="-fx-font-size: 13px; -fx-padding: 11px 28px; -fx-background-color: linear-gradient(to bottom, #76b947, #5fa032); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.3), 8, 0, 0, 2);"
                    prefWidth="200" prefHeight="44"/>
            <Button fx:id="btnCloud"
                    text="☁️ Envoyer vers Cloud"
                    onAction="#handleCloudAction"
                    style="-fx-font-size: 13px; -fx-padding: 11px 22px; -fx-background-color: linear-gradient(to bottom, #3498db, #2980b9); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(52, 152, 219, 0.2), 6, 0, 0, 1);"
                    prefHeight="44"/>
        </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>

