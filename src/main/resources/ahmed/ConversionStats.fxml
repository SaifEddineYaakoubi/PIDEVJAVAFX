<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 25; -fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.ahmed.ConversionStatsController">
    <children>
        <!-- HEADER CARD -->
        <VBox spacing="12" style="-fx-padding: 25; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;" text="📈 Taux de Conversion" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <!-- SUMMARY CARDS -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #f8d7da; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(217, 83, 79, 0.3), 10, 0, 0, 2); -fx-min-width: 150;" alignment="CENTER">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #721c24;" text="Total inactifs" />
                <Label fx:id="totalInactiveLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #d9534f;" text="0" />
            </VBox>

            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #d4edda; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(40, 167, 69, 0.3), 10, 0, 0, 2); -fx-min-width: 150;" alignment="CENTER">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #155724;" text="Convertis" />
                <Label fx:id="convertedLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #28a745;" text="0 / 0" />
            </VBox>

            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #cfe2ff; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(13, 110, 253, 0.3), 10, 0, 0, 2); -fx-min-width: 150;" alignment="CENTER">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #084298;" text="Taux de conversion" />
                <Label fx:id="rateLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" text="0.0%" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- CHART CARD -->
        <VBox style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.1), 12, 0, 0, 3);" VBox.vgrow="ALWAYS">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;" text="Répartition des Conversions" />
            <BarChart fx:id="conversionChart" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis side="BOTTOM" />
                </xAxis>
                <yAxis>
                    <NumberAxis side="LEFT" />
                </yAxis>
            </BarChart>
        </VBox>

        <!-- ACTION BUTTONS CARD -->
        <HBox alignment="CENTER" spacing="12" style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.08), 10, 0, 0, 2);">
            <Button onAction="#handleRefresh" style="-fx-font-size: 13px; -fx-padding: 11px 22px; -fx-background-color: linear-gradient(to bottom, #76b947, #5fa032); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(118, 185, 71, 0.2), 6, 0, 0, 1);" text="🔄 Actualiser" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleClose" style="-fx-font-size: 13px; -fx-padding: 11px 22px; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="✕ Fermer" />
        </HBox>
    </children>
</VBox>

