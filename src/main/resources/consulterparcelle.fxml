<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ConsulterParcelleController"
            prefHeight="550.0" prefWidth="900.0" style="-fx-background-color: #FFFFFF;">

    <!-- Barre de navigation -->
    <HBox spacing="10" style="-fx-background-color: #2E7D32; -fx-padding: 10;" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Button text="📋 Liste Parcelles" 
                style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="➕ Ajouter Parcelle" onAction="#navigateToAjouterParcelle"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="📋 Liste Cultures" onAction="#navigateToConsulterCulture"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="➕ Ajouter Culture" onAction="#navigateToAjouterCulture"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <VBox spacing="15" AnchorPane.topAnchor="60" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- Titre et Recherche -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="📋 Liste des Parcelles" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="tfRecherche" promptText="Rechercher par nom, localisation ou état..." prefWidth="300"
                           style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5; -fx-padding: 8;"/>
            </HBox>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="tableViewParcelles" VBox.vgrow="ALWAYS" style="-fx-border-color: #8D6E63; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="180">
                    <cellValueFactory><PropertyValueFactory property="nom"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colSuperficie" text="Superficie (m²)" prefWidth="130">
                    <cellValueFactory><PropertyValueFactory property="superficie"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colLocalisation" text="Localisation" prefWidth="250">
                    <cellValueFactory><PropertyValueFactory property="localisation"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colEtat" text="État" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="etat"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER">
            <Button text="🔄 Rafraîchir" onAction="#rafraichirListe"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Button text="✏️ Modifier" onAction="#modifierParcelle"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
            <Button text="🗑️ Supprimer" onAction="#supprimerParcelle"
                    style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Label de message -->
        <Label fx:id="lblMessage" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
        
    </VBox>
    
</AnchorPane>
