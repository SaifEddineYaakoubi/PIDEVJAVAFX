<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.ConsulterParcelleController"
            prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: linear-gradient(to bottom, #E8F5E9, #FFFFFF);">

    <!-- Barre de navigation -->
    <HBox spacing="10" style="-fx-background-color: linear-gradient(to right, #1B5E20, #2E7D32); -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 2);"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Button text="📋 Liste Parcelles"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #1B5E20; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 20; -fx-padding: 8 20;"/>
        <Button text="➕ Ajouter Parcelle" onAction="#navigateToAjouterParcelle"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 20; -fx-padding: 8 20;"/>
        <Button text="📋 Liste Cultures" onAction="#navigateToConsulterCulture"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 20; -fx-padding: 8 20;"/>
        <Button text="➕ Ajouter Culture" onAction="#navigateToAjouterCulture"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: white; -fx-border-radius: 20; -fx-padding: 8 20;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblDateTime" text="" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
    </HBox>

    <VBox spacing="15" AnchorPane.topAnchor="65" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- Cartes de statistiques -->
        <HBox spacing="15" alignment="CENTER">
            <!-- Compteur Total -->
            <VBox alignment="CENTER" spacing="5" prefWidth="200" prefHeight="100"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-padding: 15;">
                <Label text="📊 Total Parcelles" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <Label fx:id="lblTotalParcelles" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            </VBox>
            <!-- Superficie Totale -->
            <VBox alignment="CENTER" spacing="5" prefWidth="200" prefHeight="100"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-padding: 15;">
                <Label text="📐 Superficie Totale" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <Label fx:id="lblSuperficieTotale" text="0 m²" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
            </VBox>
            <!-- Actives -->
            <VBox alignment="CENTER" spacing="5" prefWidth="160" prefHeight="100"
                  style="-fx-background-color: #E8F5E9; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-padding: 15;">
                <Label text="✅ Actives" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <Label fx:id="lblActives" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
            </VBox>
            <!-- En Repos -->
            <VBox alignment="CENTER" spacing="5" prefWidth="160" prefHeight="100"
                  style="-fx-background-color: #FFF3E0; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-padding: 15;">
                <Label text="💤 En Repos" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <Label fx:id="lblRepos" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
            </VBox>
            <!-- Exploitées -->
            <VBox alignment="CENTER" spacing="5" prefWidth="160" prefHeight="100"
                  style="-fx-background-color: #E3F2FD; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-padding: 15;">
                <Label text="🚜 Exploitées" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <Label fx:id="lblExploitees" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            </VBox>
        </HBox>

        <!-- Titre et Recherche -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="📋 Liste des Parcelles" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <ComboBox fx:id="cbFiltre" promptText="Filtrer par état" prefWidth="150"
                          style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 5;"/>
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="tfRecherche" promptText="Rechercher..." prefWidth="250"
                           style="-fx-background-color: #FFFFFF; -fx-border-color: #8D6E63; -fx-border-radius: 20; -fx-padding: 8 15;"/>
            </HBox>
        </HBox>

        <!-- TableView avec style amélioré -->
        <TableView fx:id="tableViewParcelles" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-background-radius: 10;">
            <columns>
                <TableColumn fx:id="colNom" text="📝 Nom" prefWidth="180">
                    <cellValueFactory><PropertyValueFactory property="nom"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colSuperficie" text="📐 Superficie (m²)" prefWidth="140">
                    <cellValueFactory><PropertyValueFactory property="superficie"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colLocalisation" text="📍 Localisation" prefWidth="280">
                    <cellValueFactory><PropertyValueFactory property="localisation"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colEtat" text="🏷️ État" prefWidth="150">
                    <cellValueFactory><PropertyValueFactory property="etat"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER">
            <Button text="➕ Ajouter" onAction="#navigateToAjouterParcelle"
                    style="-fx-background-color: linear-gradient(to bottom, #2196F3, #1976D2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button text="🔄 Rafraîchir" onAction="#rafraichirListe"
                    style="-fx-background-color: linear-gradient(to bottom, #4CAF50, #388E3C); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button text="✏️ Modifier" onAction="#modifierParcelle"
                    style="-fx-background-color: linear-gradient(to bottom, #FF9800, #F57C00); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button text="🗑️ Supprimer" onAction="#supprimerParcelle"
                    style="-fx-background-color: linear-gradient(to bottom, #F44336, #D32F2F); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📄 Exporter" onAction="#exporterListe"
                    style="-fx-background-color: linear-gradient(to bottom, #607D8B, #455A64); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
        </HBox>

        <!-- Barre de statut -->
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #F5F5F5; -fx-padding: 10; -fx-background-radius: 10;">
            <Label fx:id="lblMessage" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblResultats" text="Affichage: 0 sur 0" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        </HBox>

    </VBox>
    
</AnchorPane>
