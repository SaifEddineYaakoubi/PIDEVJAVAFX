<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pidev.controllers.AIPredictionsController"
      spacing="16"
      style="-fx-padding: 0; -fx-background-color: transparent;">

    <!-- En-tête -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="🤖 Prédictions IA" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #7B1FA2;"/>
            <Label text="Rendements prédits par apprentissage automatique" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
        </VBox>
        <Button text="🔄 Rafraîchir" onAction="#handleRefreshPredictions" style="-fx-font-size: 11; -fx-padding: 8 16; -fx-background-color: #7B1FA2; -fx-text-fill: white; -fx-background-radius: 6;"/>
    </HBox>

    <!-- GridPane pour les cartes -->
    <GridPane fx:id="predictionsGridPane" hgap="12" vgap="12" style="-fx-padding: 0;">
        <columnConstraints>
            <ColumnConstraints percentWidth="33.33" />
            <ColumnConstraints percentWidth="33.33" />
            <ColumnConstraints percentWidth="33.34" />
        </columnConstraints>
    </GridPane>

    <!-- Statut API -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-background-color: #F0F0F0; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;">
        <Circle fx:id="aiStatusCircle" radius="5" fill="#999"/>
        <Label fx:id="aiStatusLabel" text="✅ Hugging Face: CONNECTÉE" HBox.hgrow="ALWAYS" style="-fx-font-size: 11; -fx-text-fill: #333;"/>
        <Label fx:id="lastAIUpdateLabel" text="Maj: --" style="-fx-font-size: 10; -fx-text-fill: #999;"/>
    </HBox>

</VBox>
