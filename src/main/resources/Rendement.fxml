<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.RendementController"
            stylesheets="@smartfarm.css">

    <!-- TOP - TOOLBAR -->
    <top>
        <HBox spacing="15" styleClass="toolbar">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="📊 Gestion des Rendements" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="➕ Ajouter Rendement" styleClass="button-primary" fx:id="btnAjouter"/>
            <Button text="🔄 Actualiser" styleClass="button-secondary" fx:id="btnActualiser"/>
        </HBox>
    </top>

    <!-- CENTER - TABLE RENDEMENTS -->
    <center>
        <VBox spacing="15" styleClass="content-area">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- SEARCH AREA -->
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Rechercher un rendement..." HBox.hgrow="ALWAYS"/>
                <Button text="🔍 Chercher" styleClass="button-secondary" fx:id="btnChercher"/>
            </HBox>

            <!-- TABLE VIEW -->
            <TableView fx:id="tableRendements" prefHeight="400">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colSurface" text="Surface (ha)" prefWidth="120"/>
                    <TableColumn fx:id="colQuantite" text="Quantité (kg)" prefWidth="120"/>
                    <TableColumn fx:id="colProductivite" text="Productivité (kg/ha)" prefWidth="150"/>
                    <TableColumn fx:id="colRecolte" text="Récolte ID" prefWidth="100"/>
                    <TableColumn fx:id="colAction" text="Actions" prefWidth="150"/>
                </columns>
            </TableView>

            <!-- STATUS BAR -->
            <HBox spacing="15" styleClass="status-bar">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label fx:id="lblTotal" text="Total: 0 rendements"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text="Prêt" styleClass="status-label"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>

