<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #faf5f0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.Stock.ConsulterStockController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- Sidebar -->
        <VBox prefWidth="280" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #1a472a, #0d2818); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 5, 0);">

            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 30 20 25 20;">
                <Label style="-fx-font-size: 45px;" text="📦" textFill="WHITE" />
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="SMART FARM" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Gestion Agricole" />
            </VBox>

            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />

            <VBox spacing="5" style="-fx-padding: 20 15;">
                <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="NAVIGATION" />

                <Button alignment="CENTER_LEFT" onAction="#getAll" prefHeight="45" prefWidth="250" style="-fx-background-color: linear-gradient(to right, #38a169, #2f855a);                                -fx-text-fill: white;                                -fx-font-size: 14px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-cursor: hand;" text="   📦  Stock" />

                <Button alignment="CENTER_LEFT" onAction="#navigateToConsulterProduit" prefHeight="45" prefWidth="250" style="-fx-background-color: linear-gradient(to right, #f7efde, #e4d1b0);                                -fx-text-fill: #1a472a;                                -fx-font-size: 14px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-cursor: hand;" text="   📦  Produits" />

                <Button onAction="#handleChatbot" alignment="CENTER_LEFT" prefHeight="45" prefWidth="250" style="-fx-background-color: linear-gradient(to right, #f7efde, #e4d1b0);                                -fx-text-fill: #1a472a;                                -fx-font-size: 14px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-cursor: hand;" text="   🤖  Assistant Agricole" />
            </VBox>

            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />

            <VBox spacing="12" style="-fx-padding: 20 15;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="📦 STATISTIQUES" />
                <VBox spacing="8" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Total Stock" />
                        <Label fx:id="lblTotalStock" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Pied de sidebar : Profil + Déconnexion -->
            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 12; -fx-background-color: rgba(0,0,0,0.18);">
                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="btnProfil" text="👤 Profil" onAction="#handleProfil" prefWidth="120" prefHeight="36"
                            style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 10;"/>
                    <Button fx:id="btnDeconnexion" text="🚪 Déconnexion" onAction="#handleDeconnexion" prefWidth="120" prefHeight="36"
                            style="-fx-background-color: rgba(239,68,68,0.2); -fx-text-fill: #fca5a5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: rgba(239,68,68,0.3); -fx-border-radius: 10;"/>
                </HBox>
                <Label text="© 2026 Smart Farm" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px;"/>
            </VBox>

        </VBox>

        <!-- Contenu principal -->
        <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">

            <!-- Header -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Liste du Stock" />
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="ajouters" onAction="#ajouterStock" style="-fx-background-color: linear-gradient(to right, #38a169, #2f855a); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 25;" text="➕ Nouvelle Stock" />
            </HBox>

            <!-- Recherche -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Rechercher par :" />
                <ComboBox fx:id="cbCritere" prefHeight="38" prefWidth="160" promptText="Critère De Recherche" />
                <TextField fx:id="tfRecherche" prefWidth="220" prefHeight="38" promptText="Valeur à rechercher..." />
                <Button onAction="#rechercherStock" style="-fx-background-color: linear-gradient(to right, #3182ce, #2b6cb0); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;" text="🔍 Rechercher" />
            </HBox>

            <!-- ListView -->
            <ListView fx:id="listStock" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d6c5b4; -fx-border-width: 1.5; -fx-padding: 10;" />

            <!-- Boutons Modifier / Supprimer / Exporter PDF -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="ups" onAction="#modifierStock" style="-fx-background-color: linear-gradient(to right, #3182ce, #2b6cb0); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 22;" text="✏️ Modifier" />
                <Button fx:id="deletes" onAction="#supprimerStock" style="-fx-background-color: linear-gradient(to right, #e53e3e, #c53030); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 22;" text="🗑️ Supprimer" />
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnExportPDFStock" onAction="#exporterPDFStock" style="-fx-background-color: linear-gradient(to right, #f59e42, #dd6b20); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 22;" text="📄 Exporter PDF" />
            </HBox>

        </VBox>

    </HBox>
</AnchorPane>
