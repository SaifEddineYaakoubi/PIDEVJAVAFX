<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.AjouterCultureController"
            prefHeight="520.0" prefWidth="650.0" style="-fx-background-color: linear-gradient(to bottom right, #FFF8E1, #FFECB3);">

    <!-- Carte du formulaire -->
    <VBox alignment="CENTER" spacing="15" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.bottomAnchor="20"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5); -fx-padding: 25;">

        <!-- Icône et Titre -->
        <VBox alignment="CENTER" spacing="3">
            <Label text="🌾" style="-fx-font-size: 40px;"/>
            <Label text="Nouvelle Culture" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #FF6F00;"/>
            <Label text="Associez une culture à une parcelle existante" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
        </VBox>

        <!-- Formulaire -->
        <GridPane hgap="15" vgap="12" alignment="CENTER">
            <!-- Type de culture -->
            <VBox spacing="3" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="🌱 Type de culture" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <TextField fx:id="tfTypeCulture" promptText="Ex: Blé, Maïs, Tomates..." prefWidth="270" prefHeight="35"
                           style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Parcelle -->
            <VBox spacing="3" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <Label text="📍 Parcelle associée" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbParcelle" promptText="Sélectionner une parcelle" prefWidth="270" prefHeight="35"
                          style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Date de plantation -->
            <VBox spacing="3" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="📅 Date de plantation" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDatePlantation" promptText="Sélectionner une date" prefWidth="270" prefHeight="35"
                            style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Date de récolte prévue -->
            <VBox spacing="3" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <Label text="📆 Date récolte prévue" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDateRecoltePrevue" promptText="Sélectionner une date" prefWidth="270" prefHeight="35"
                            style="-fx-background-color: #F5F5F5; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-font-size: 12px;"/>
            </VBox>

            <!-- État de croissance -->
            <VBox spacing="3" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" alignment="CENTER">
                <Label text="🏷️ État de croissance" style="-fx-font-size: 11px; -fx-text-fill: #5D4037; -fx-font-weight: bold;"/>
                <HBox spacing="12" alignment="CENTER">
                    <RadioButton fx:id="rbGermination" text="🌱 Germination" style="-fx-font-size: 11px;"/>
                    <RadioButton fx:id="rbCroissance" text="🌿 Croissance" style="-fx-font-size: 11px;"/>
                    <RadioButton fx:id="rbFloraison" text="🌸 Floraison" style="-fx-font-size: 11px;"/>
                    <RadioButton fx:id="rbMaturite" text="🌾 Maturité" style="-fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </GridPane>

        <!-- Aperçu des jours -->
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #E3F2FD; -fx-padding: 8 15; -fx-background-radius: 8;">
            <Label text="⏱️ Durée estimée:" style="-fx-font-size: 12px; -fx-text-fill: #1565C0; -fx-font-weight: bold;"/>
            <Label fx:id="lblDureeEstimee" text="-- jours" style="-fx-font-size: 12px; -fx-text-fill: #1565C0;"/>
        </HBox>

        <!-- Messages -->
        <VBox alignment="CENTER" spacing="3">
            <Label fx:id="lblError" style="-fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="500"/>
            <Label fx:id="lblSuccess" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="btnAjouter" text="✓ Enregistrer" onAction="#ajouterCulture" prefWidth="150" prefHeight="38"
                    style="-fx-background-color: linear-gradient(to bottom, #FF9800, #F57C00); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button fx:id="btnReset" text="🔄 Réinitialiser" onAction="#resetForm" prefWidth="130" prefHeight="38"
                    style="-fx-background-color: linear-gradient(to bottom, #4CAF50, #388E3C); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
            <Button fx:id="btnAnnuler" text="✗ Fermer" onAction="#fermerFenetre" prefWidth="110" prefHeight="38"
                    style="-fx-background-color: linear-gradient(to bottom, #9E9E9E, #757575); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);"/>
        </HBox>

        <!-- Indication -->
        <Label text="💡 La date de récolte doit être postérieure à la date de plantation" style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E;"/>

    </VBox>

</AnchorPane>
