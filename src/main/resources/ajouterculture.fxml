<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.pidev.controllers.culture.AjouterCultureController"
            prefHeight="650.0" prefWidth="720.0"
            style="-fx-background-color: linear-gradient(to bottom right, #f5af19, #f12711);">

    <!-- Carte du formulaire -->
    <VBox alignment="CENTER" spacing="20"
          AnchorPane.topAnchor="25" AnchorPane.leftAnchor="35" AnchorPane.rightAnchor="35" AnchorPane.bottomAnchor="25"
          style="-fx-background-color: white; -fx-background-radius: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 35;">

        <!-- En-tête avec icône -->
        <VBox alignment="CENTER" spacing="6">
            <StackPane prefWidth="75" prefHeight="75"
                       style="-fx-background-color: linear-gradient(to bottom right, #f5af19, #f12711); -fx-background-radius: 38;">
                <Label text="🌾" style="-fx-font-size: 38px;"/>
            </StackPane>
            <Label text="Nouvelle Culture" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
            <Label text="Enregistrez une nouvelle culture dans votre exploitation" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
        </VBox>

        <!-- Formulaire -->
        <GridPane hgap="18" vgap="15" alignment="CENTER">
            <!-- Type de culture -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="🌱 Type de culture" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <TextField fx:id="tfTypeCulture" promptText="Ex: Blé, Maïs, Tomates..." prefWidth="300" prefHeight="42"
                           style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 15; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Parcelle -->
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <Label text="📍 Parcelle associée" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbParcelle" promptText="Sélectionner une parcelle" prefWidth="300" prefHeight="42"
                          style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Date de plantation -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="📅 Date de plantation" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDatePlantation" promptText="Sélectionner une date" prefWidth="300" prefHeight="42"
                            style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Date de récolte prévue -->
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <Label text="📆 Date récolte prévue" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDateRecoltePrevue" promptText="Sélectionner une date" prefWidth="300" prefHeight="42"
                            style="-fx-background-color: #faf5f0; -fx-border-color: #ddd0c8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;"/>
            </VBox>

            <!-- État de croissance -->
            <VBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2" alignment="CENTER">
                <Label text="🏷️ État de croissance" style="-fx-font-size: 11px; -fx-text-fill: #4a5568; -fx-font-weight: bold;"/>
                <HBox spacing="20" alignment="CENTER" style="-fx-background-color: #faf5f0; -fx-padding: 15 25; -fx-background-radius: 12;">
                    <RadioButton fx:id="rbGermination" text="🌱 Germination" style="-fx-font-size: 12px; -fx-text-fill: #2e7d32;"/>
                    <RadioButton fx:id="rbCroissance" text="🌿 Croissance" style="-fx-font-size: 12px; -fx-text-fill: #1565c0;"/>
                    <RadioButton fx:id="rbFloraison" text="🌸 Floraison" style="-fx-font-size: 12px; -fx-text-fill: #c2185b;"/>
                    <RadioButton fx:id="rbMaturite" text="🌻 Maturité" style="-fx-font-size: 12px; -fx-text-fill: #ef6c00;"/>
                </HBox>
            </VBox>
        </GridPane>

        <!-- Aperçu des jours -->
        <HBox spacing="12" alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #e3f2fd, #bbdefb); -fx-padding: 12 25; -fx-background-radius: 12;">
            <Label text="⏱️" style="-fx-font-size: 18px;"/>
            <Label text="Durée de culture estimée:" style="-fx-font-size: 13px; -fx-text-fill: #1565C0; -fx-font-weight: bold;"/>
            <Label fx:id="lblDureeEstimee" text="-- jours" style="-fx-font-size: 15px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Messages -->
        <VBox alignment="CENTER" spacing="4" minHeight="35">
            <Label fx:id="lblError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="580"/>
            <Label fx:id="lblSuccess" style="-fx-text-fill: #38a169; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="btnAjouter" text="✓ Enregistrer" onAction="#ajouterCulture" prefWidth="170" prefHeight="48"
                    style="-fx-background-color: linear-gradient(to right, #f5af19, #f12711); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(241,39,17,0.5), 15, 0, 0, 5);"/>
            <Button fx:id="btnReset" text="🔄 Réinitialiser" onAction="#resetForm" prefWidth="155" prefHeight="48"
                    style="-fx-background-color: linear-gradient(to right, #56ab2f, #a8e063); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(86,171,47,0.4), 12, 0, 0, 4);"/>
            <Button fx:id="btnAnnuler" text="✗ Fermer" onAction="#fermerFenetre" prefWidth="125" prefHeight="48"
                    style="-fx-background-color: linear-gradient(to right, #bdc3c7, #95a5a6); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(149,165,166,0.4), 12, 0, 0, 4);"/>
        </HBox>

        <!-- Indication -->
        <HBox spacing="8" alignment="CENTER" style="-fx-background-color: #fff8e1; -fx-padding: 10 18; -fx-background-radius: 10;">
            <Label text="💡" style="-fx-font-size: 14px;"/>
            <Label text="La date de récolte doit être après la date de plantation" style="-fx-font-size: 11px; -fx-text-fill: #f57c00;"/>
        </HBox>

    </VBox>

</AnchorPane>
