<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.*?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.pidev.controllers.utilisateur.UserFormController"
            prefHeight="680.0" prefWidth="560.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f2027, #203a43, #2c5364);">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="20" AnchorPane.leftAnchor="30"
          AnchorPane.rightAnchor="30" AnchorPane.bottomAnchor="20"
          styleClass="user-form-card" stylesheets="@styles/smartfarm.css">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="6" styleClass="user-form-header">
            <Label text="👤" style="-fx-font-size: 36px;"/>
            <Label fx:id="formTitle" text="Détails de l'utilisateur" styleClass="form-title"/>
            <Label text="Remplissez les informations ci-dessous" styleClass="form-subtitle"/>
        </VBox>

        <!-- Thin accent bar -->
        <HBox style="-fx-pref-height: 3; -fx-background-color: linear-gradient(to right, #4CAF50, #81C784, #4CAF50);"/>

        <!-- Body -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="22" styleClass="user-form-body">

                <!-- Photo Section -->
                <VBox spacing="10" alignment="CENTER" styleClass="photo-section">
                    <Label text="Photo de profil" styleClass="form-label" style="-fx-font-size: 13px;"/>
                    <HBox spacing="20" alignment="CENTER">
                        <ImageView fx:id="profileImageView" fitWidth="100" fitHeight="100"
                                   preserveRatio="true" styleClass="profile-avatar"/>
                        <VBox spacing="8" alignment="CENTER_LEFT">
                            <Button fx:id="uploadPhotoButton" text="📷  Choisir une photo"
                                    styleClass="btn-primary" prefWidth="160"/>
                            <Button fx:id="removePhotoButton" text="🗑  Supprimer"
                                    styleClass="btn-secondary" prefWidth="160"/>
                            <Label text="JPG, PNG, GIF • Max 5 Mo"
                                   style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Form Fields -->
                <VBox spacing="6">
                    <Label text="Nom Complet" styleClass="form-label"/>
                    <TextField fx:id="nomField" promptText="Ex: Jean Dupont" styleClass="text-field-modern"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Adresse Email" styleClass="form-label"/>
                    <TextField fx:id="emailField" promptText="email@exemple.com" styleClass="text-field-modern"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Mot de passe" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-field-modern"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Rôle de l'utilisateur" styleClass="form-label"/>
                    <ComboBox fx:id="roleCombo" maxWidth="Infinity" styleClass="combo-box-modern"
                              promptText="Sélectionner un rôle">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="ADMIN"/>
                                <String fx:value="AGRICULTEUR"/>
                                <String fx:value="RESPONSABLE_STOCK"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- Thin line -->
        <HBox style="-fx-pref-height: 1; -fx-background-color: #e2e8f0;"/>

        <!-- Actions -->
        <HBox spacing="12" alignment="CENTER" styleClass="user-form-actions">
            <Button fx:id="saveButton" text="✓  Enregistrer" onAction="#handleSave"
                    styleClass="btn-success" prefWidth="150"/>
            <Button text="✗  Annuler" onAction="#handleCancel"
                    styleClass="btn-secondary" prefWidth="120"/>
            <Button text="📸  Face ID" onAction="#handleFaceCapture"
                    styleClass="btn-primary" prefWidth="130"/>
        </HBox>

    </VBox>
</AnchorPane>

