<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" style="-fx-padding: 25; -fx-background-color: #f4f7f6;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pidev.controllers.ventes.AjouterClientController">
    <children>
        <!-- HEADER CARD -->
        <VBox spacing="8" style="-fx-padding: 25; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.12), 15, 0, 0, 4);">
            <Label text="👤 Ajouter / Modifier un Client" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
            <Label text="Complétez les informations ci-dessous" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <!-- FORM CARD -->
        <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.08), 10, 0, 0, 3);">
            <!-- SECTION 1: NOM & PRENOM -->
            <VBox spacing="12">
                <Label text="📋 Informations Personnelles" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <HBox spacing="15">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nom" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <TextField fx:id="nomField" promptText="Ex: Conseil" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prénom" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <TextField fx:id="prenomField" promptText="Ex: Agronomique" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator style="-fx-border-color: #ecf0f1;"/>

            <!-- SECTION 2: CONTACT -->
            <VBox spacing="12">
                <Label text="📧 Informations de Contact" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <VBox spacing="6">
                    <Label text="Email" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="emailField" promptText="Ex: contact@exemple.com" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Téléphone" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="telephoneField" promptText="Ex: +216 71 234 567" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                </VBox>
            </VBox>

            <Separator style="-fx-border-color: #ecf0f1;"/>

            <!-- SECTION 3: ADRESSE -->
            <VBox spacing="12">
                <Label text="📍 Adresse" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
                <VBox spacing="6">
                    <Label text="Rue / Adresse" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="adresseField" promptText="Ex: Rue de l'Agriculture, Immeuble 10" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Ville" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="villeField" promptText="Ex: Tunis" style="-fx-font-size: 12px; -fx-padding: 10px 12px; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #ecf0f1; -fx-background-color: #f9fafb;"/>
                </VBox>
            </VBox>
        </VBox>

        <!-- ACTION BUTTONS CARD -->
        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.08), 10, 0, 0, 2);">
            <Button text="✓ Enregistrer" onAction="#handleEnregistrer" style="-fx-font-size: 13px; -fx-padding: 11px 28px; -fx-background-color: linear-gradient(to bottom, #76b947, #5fa032); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45, 90, 39, 0.3), 8, 0, 0, 2);" prefWidth="140"/>
            <Button text="✗ Annuler" onAction="#handleAnnuler" style="-fx-font-size: 13px; -fx-padding: 11px 28px; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(231, 76, 60, 0.2), 6, 0, 0, 1);" prefWidth="140"/>
        </HBox>
    </children>
</VBox>

