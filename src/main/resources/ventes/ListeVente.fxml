<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.ventes.ListeVenteController">

    <stylesheets>
        <URL value="@smartfarm.css" />
    </stylesheets>

    <children>
        <!-- HEADER SECTION -->
        <VBox spacing="5" styleClass="dashboard-header">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label styleClass="dashboard-title" text="📈 Gestion des Ventes" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleAjouter" styleClass="btn-add" text="+ Nouvelle Vente" />
            </HBox>
            <Label styleClass="dashboard-subtitle" text="Consultez l'historique et gérez les transactions de la ferme" />
        </VBox>

        <!-- SEARCH & FILTER SECTION -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="activities-section" style="-fx-padding: 20;">
            <Label styleClass="activity-title" text="Rechercher :" />
            <TextField fx:id="searchIdField" promptText="Rechercher par client..." styleClass="text-field" HBox.hgrow="ALWAYS" />
            <Button onAction="#handleSearchById" styleClass="btn-edit" text="Chercher" />
            <Button onAction="#handleResetSearch" styleClass="btn-secondary" text="↻" />
        </HBox>

        <!-- TABLE VIEW SECTION -->
        <VBox VBox.vgrow="ALWAYS" styleClass="activities-section" style="-fx-padding: 15;">
            <TableView fx:id="venteTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80" visible="false" />
                    <TableColumn fx:id="colDate" text="Date de Vente" prefWidth="150" />
                    <TableColumn fx:id="colClient" text="Client" prefWidth="200" />
                    <TableColumn fx:id="colMontant" text="Montant (TND)" prefWidth="120" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- ACTION BUTTONS SECTION -->
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="activities-section" style="-fx-padding: 15;">
            <Button onAction="#handleModifier" styleClass="btn-edit" text="✏️ Modifier" />
            <Button onAction="#handleSupprimer" styleClass="btn-delete" text="🗑️ Supprimer" />
            <Separator orientation="VERTICAL" />
            <Button onAction="#handleExportPDF" styleClass="sidebar-button-orange" style="-fx-pref-width: 150; -fx-pref-height: 40;" text="📄 PDF" />
            <Button onAction="#handleStatistiques" styleClass="sidebar-button-yellow" style="-fx-pref-width: 150; -fx-pref-height: 40;" text="📊 Stats" />
        </HBox>
    </children>
</VBox>
