<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #faf5f0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pidev.controllers.ConsulterStockController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <VBox prefWidth="280" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #1a472a, #0d2818); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 5, 0);">
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 30 20 25 20;">
                <Label style="-fx-font-size: 45px;" text="📦" />
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="SMART FARM" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Gestion Agricole" />
            </VBox>
            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />
            <VBox spacing="5" style="-fx-padding: 20 15;">
                <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="NAVIGATION" />
                <Button alignment="CENTER_LEFT" onAction="#getAll" prefHeight="45" prefWidth="250" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="   📦  Stock" />
                <Button alignment="CENTER_LEFT" onAction="#navigateToConsulterProduit" prefHeight="45" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px; -fx-background-radius: 10; -fx-cursor: hand;" text="   📦  Produits" />
            </VBox>
            <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1;" />
                <VBox spacing="12" style="-fx-padding: 20 15;" VBox.vgrow="ALWAYS">
                    <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold;" text="📦 STATISTIQUES" />
                    <VBox spacing="8" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 18;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane prefHeight="45" prefWidth="45" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 12;">
                                <Label style="-fx-font-size: 20px;" text="📦" />
                            </StackPane>
                            <VBox spacing="2">
                                <Label style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);" text="Total Stock" />
                                <Label fx:id="lblTotalStock" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
        </VBox>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <!-- Barre de recherche -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
            <children>
                  <AnchorPane prefHeight="91.0" prefWidth="814.0">
                      <children>
                          <Button fx:id="ajouters" disable="false" layoutX="699.0" layoutY="49.0" onAction="#ajouterStock" style="-fx-background-color: #38a169; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="➕ Nouvelle Stock" />
                          <Label layoutX="24.0" layoutY="14.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Liste du Stock" />
                         <Label layoutX="10.0" layoutY="52.0" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Rechercher par :" />
                         <ComboBox fx:id="cbCritere" layoutX="124.0" layoutY="49.0" prefHeight="26.0" prefWidth="160.0" promptText="Critère De Recherche" />
                         <TextField fx:id="tfRecherche" layoutX="315.0" layoutY="49.0" prefWidth="200" promptText="Valeur à rechercher..." />
                         <Button layoutX="526.0" layoutY="49.0" onAction="#rechercherStock" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="🔍Rechercher" />
                      </children>
                  </AnchorPane>
            </children>
            </HBox>
            <HBox alignment="CENTER" spacing="12" />
            <TableView fx:id="tableStock" prefHeight="400" prefWidth="814.0">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                    <TableColumn fx:id="colNomProduit" prefWidth="150" text="Nom du produit" />
                    <TableColumn fx:id="colTypeProduit" prefWidth="100" text="Type" />
                    <TableColumn fx:id="colQuantite" prefWidth="100" text="Quantité" />
                    <TableColumn fx:id="colPrixUnitaire" prefWidth="150" text="Prix unitaire (par unité)" />
                    <TableColumn fx:id="colDateEntree" prefWidth="120" text="Date d'entrée" />
                    <TableColumn fx:id="colDateExpiration" prefWidth="120" text="Date de sortie" />
                </columns>
            </TableView>
            <AnchorPane prefHeight="26.0" prefWidth="600.0">
                <children>
                         <Button fx:id="ups" disable="false" layoutX="14.0" layoutY="14.0" onAction="#modifierStock" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="✏️ Modifier" />
                         <Button fx:id="deletes" disable="false" layoutX="135.0" layoutY="14.0" onAction="#supprimerStock" style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="🗑️ Supprimer" />
                         <Button fx:id="btnExportPDFStock" layoutX="703.0" layoutY="7.0" onAction="#exporterPDFStock" style="-fx-background-color: #f59e42; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="📄 Exporter PDF" />
                </children>
            </AnchorPane>
        </VBox>
    </HBox>
</AnchorPane>
